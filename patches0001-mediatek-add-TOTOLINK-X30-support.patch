From 1e4bed859aeb3c7047ee602866d833efed853e2d Mon Sep 17 00:00:00 2001
From: sing <wx9745@gmail.com>
Date: Sat, 6 Dec 2025 11:51:27 +0800
Subject: [PATCH] mediatek: add TOTOLINK X30 support
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Hardware specification:
  SoC: MediaTek MT7981B 2x A53
  Flash: 128 MB SPI-NAND
  RAM: 256MB
  Ethernet: 5x 10/100/1000 Mbps
  Switch: MediaTek MT7531AE
  WiFi: MediaTek MT7976C
  Button: Reset, Mesh
  Power: DC 12V 1A

Flash Installation (UART)：
  1. Connect to your PC via the Gigabit port of the router,
     set a static ip on the ethernet interface of your PC.
     (ip 192.168.1.254, gateway 192.168.1.1)
  2. Attach UART, pause at u-boot menu.
  3. Select <Upgrade ATF FIP>, then use openwrt-mediatek-filogic-totolink_X30-bl31-uboot.fip
  4. Restart the system, pause at u-boot menu.
  5. Select <Load production system via TFTP then write to NAND>, then use openwrt-mediatek-filogic-totolink_X30-squashfs-sysupgrade.bin ,
 waiting for tftp recovery to complete, and input Enter.

Signed-off-by: sing <wx9745@gmail.com>
---
 package/boot/uboot-mediatek/Makefile          |  13 +
 .../patches/510-add-totolink-X30.patch        | 355 ++++++++++++++++++
 .../mediatek/dts/mt7981b-totolink-X30.dts     | 303 +++++++++++++++
 target/linux/mediatek/image/filogic.mk        |  24 ++
 4 files changed, 695 insertions(+)
 create mode 100644 package/boot/uboot-mediatek/patches/510-add-totolink-X30.patch
 create mode 100644 target/linux/mediatek/dts/mt7981b-totolink-X30.dts

diff --git a/package/boot/uboot-mediatek/Makefile b/package/boot/uboot-mediatek/Makefile
index 2431d4fd9604eb..4f368de236f6ee 100644
--- a/package/boot/uboot-mediatek/Makefile
+++ b/package/boot/uboot-mediatek/Makefile
@@ -434,6 +434,18 @@ define U-Boot/mt7981_nokia_ea0326gmp
   DEPENDS:=+trusted-firmware-a-mt7981-spim-nand-ddr3
 endef
 
+define U-Boot/mt7981_totolink_X30
+  NAME:=TOTOLINK X30
+  BUILD_SUBTARGET:=filogic
+  BUILD_DEVICES:=totolink_X30
+  UBOOT_CONFIG:=mt7981_totolink_X30
+  UBOOT_IMAGE:=u-boot.fip
+  BL2_BOOTDEV:=spim-nand
+  BL2_SOC:=mt7981
+  BL2_DDRTYPE:=ddr3
+  DEPENDS:=+trusted-firmware-a-mt7981-spim-nand-ddr3
+endef
+
 define U-Boot/mt7981_openwrt_one-snand
   NAME:=OpenWrt One NAND
   BUILD_SUBTARGET:=filogic
@@ -1114,6 +1126,7 @@ UBOOT_TARGETS := \
 	mt7981_snr_snr-cpe-ax2 \
 	mt7981_xiaomi_mi-router-ax3000t \
 	mt7981_xiaomi_mi-router-wr30u \
+	mt7981_totolink_X30 \
 	mt7986_acer_predator-w6x \
 	mt7986_bananapi_bpi-r3-emmc \
 	mt7986_bananapi_bpi-r3-sdmmc \
diff --git a/package/boot/uboot-mediatek/patches/510-add-totolink-X30.patch b/package/boot/uboot-mediatek/patches/510-add-totolink-X30.patch
